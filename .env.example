# Local/dev example. In production set these in Render's environment.
DEBUG=True
SECRET_KEY=change-me
DATABASE_URL=postgres://user:password@host:5432/dbname
ALLOWED_HOSTS=*
CSRF_TRUSTED_ORIGINS=https://*.onrender.com

# SMS (verification disabled for now)
SMS_BACKEND=off
PHONE_VERIFICATION_REQUIRED=False
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
